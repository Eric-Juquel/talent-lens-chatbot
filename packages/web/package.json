{
  "name": "talent-lens-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:package": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "check": "biome check --config-path . ./src",
    "check:fix": "biome check --config-path . --write ./src",
    "lint": "biome lint --config-path . ./src",
    "lint:fix": "biome lint --config-path . --write ./src",
    "format": "biome format --config-path . --write ./src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "generate:api": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-query": "5.95.2",
    "axios": "1.15.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "i18next": "26.0.3",
    "lucide-react": "1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-i18next": "17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.13.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "concurrently": "9.2.1",
    "jsdom": "^29.0.1",
    "msw": "2.12.14",
    "orval": "8.6.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  }
}

{
  "name": "talent-lens-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:package": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "tsc --noEmit && biome lint --config-path . src/",
    "format": "biome check --config-path . src/ --write",
    "openapi:export": "ts-node -r tsconfig-paths/register scripts/export-openapi.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "body-parser": "2.2.2",
    "helmet": "8.1.0",
    "joi": "18.1.2",
    "jsonrepair": "^3.13.3",
    "mammoth": "^1.12.0",
    "multer": "2.1.1",
    "nestjs-zod": "5.2.1",
    "openai": "6.33.0",
    "pdf-parse": "2.4.5",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.17",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@swc/core": "1.15.21",
    "@types/body-parser": "1.19.6",
    "@types/express": "5.0.6",
    "@types/js-yaml": "4.0.9",
    "@types/multer": "2.1.0",
    "@types/node": "25.5.0",
    "@types/pdf-parse": "1.1.5",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.2",
    "dotenv-cli": "11.0.0",
    "js-yaml": "4.1.1",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.2"
  }
}
